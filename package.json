{
	"name": "crosshair-vscode",
	"displayName": "crosshair-vscode",
	"description": "Use crosshair to statically analyze Python code from within VS Code.",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.52.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onLanguage:python"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "crosshair-vscode.check",
				"title": "crosshair check"
			},
			{
				"command": "crosshair-vscode.watch",
				"title": "crosshair watch"
			}
		],
		 "menus": {
            "editor/context": [
                {
                    "when": "resourceLangId == python",
                    "command": "crosshair-vscode.check",
                    "group": "z_crosshair-vscode"
                },
				{
                    "when": "resourceLangId == python",
                    "command": "crosshair-vscode.watch",
                    "group": "z_crosshair-vscode"
                }
			],
			"explorer/context": [
				{
					"command": "crosshair-vscode.check",
					"group": "z_crosshair-vscode"
				},
				{
					"command": "crosshair-vscode.watch",
					"group": "z_crosshair-vscode"
				}
			]
        }
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/vscode": "^1.52.0",
		"@types/glob": "^7.1.3",
		"@types/mocha": "^8.0.4",
		"@types/node": "^12.11.7",
		"eslint": "^7.15.0",
		"@typescript-eslint/eslint-plugin": "^4.9.0",
		"@typescript-eslint/parser": "^4.9.0",
		"glob": "^7.1.6",
		"mocha": "^8.1.3",
		"typescript": "^4.1.2",
		"vscode-test": "^1.4.1"
	},
	"extensionDependencies": [
		"ms-python.python"
	]
}
